<div class="stat-card mb-2 <%= isOverdue ? 'border-danger' : '' %>">
  <div class="d-flex align-items-center justify-content-between">
    <div class="d-flex align-items-center gap-3">
      <!-- Чекбокс статуса -->
      <div>
        <% if (task.status === 'done') { %>
          <button onclick="changeStatus('<%= task.id %>', 'open')" class="btn btn-sm btn-success rounded-circle p-1">
            <i class="bi bi-check-lg"></i>
          </button>
        <% } else { %>
          <button onclick="changeStatus('<%= task.id %>', 'done')" class="btn btn-sm btn-outline-secondary rounded-circle p-1">
            <i class="bi bi-circle"></i>
          </button>
        <% } %>
      </div>
      <div>
        <div class="fw-semibold <%= task.status === 'done' ? 'text-decoration-line-through text-muted' : '' %>">
          <%= task.title %>
        </div>
        <div class="d-flex gap-2 mt-1">
          <% if (task.deadline) { %>
            <span class="text-<%= isOverdue ? 'danger' : 'muted' %> small">
              <i class="bi bi-calendar me-1"></i><%= new Date(task.deadline).toLocaleDateString('ru-RU') %>
            </span>
          <% } %>
          <% if (task.client) { %>
            <span class="text-muted small"><i class="bi bi-building me-1"></i><%= task.client.name %></span>
          <% } %>
          <% if (task.deal) { %>
            <span class="text-muted small"><i class="bi bi-kanban me-1"></i><%= task.deal.title %></span>
          <% } %>
        </div>
      </div>
    </div>
    <div class="d-flex align-items-center gap-2">
      <% const prBadge = { low: 'secondary', medium: 'warning', high: 'danger' } %>
      <% const prMap = { low: 'Низкий', medium: 'Средний', high: 'Высокий' } %>
      <span class="badge bg-<%= prBadge[task.priority] %>"><%= prMap[task.priority] %></span>
      <% const stMap = { open: ['secondary', 'Открыта'], in_progress: ['primary', 'В работе'], done: ['success', 'Закрыта'] } %>
      <span class="badge bg-<%= stMap[task.status][0] %>"><%= stMap[task.status][1] %></span>
      <a href="/tasks/<%= task.id %>/edit" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-pencil"></i>
      </a>
    </div>
  </div>
</div>