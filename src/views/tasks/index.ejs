<!DOCTYPE html>
<html lang="ru">
<head><%- include('../partials/head') %></head>
<body>
<div class="app-layout">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/navbar') %>
    <div class="page-content">

      <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 class="fw-bold mb-0">Задачи</h5>
        <a href="/tasks/new" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Новая задача</a>
      </div>

      <!-- Фильтры -->
      <form method="GET" action="/tasks" class="row g-2 mb-4">
        <div class="col-md-3">
          <select name="status" class="form-select">
            <option value="">Все статусы</option>
            <option value="open" <%= status === 'open' ? 'selected' : '' %>>Открыта</option>
            <option value="in_progress" <%= status === 'in_progress' ? 'selected' : '' %>>В работе</option>
            <option value="done" <%= status === 'done' ? 'selected' : '' %>>Закрыта</option>
          </select>
        </div>
        <div class="col-md-3">
          <select name="priority" class="form-select">
            <option value="">Все приоритеты</option>
            <option value="high" <%= priority === 'high' ? 'selected' : '' %>>Высокий</option>
            <option value="medium" <%= priority === 'medium' ? 'selected' : '' %>>Средний</option>
            <option value="low" <%= priority === 'low' ? 'selected' : '' %>>Низкий</option>
          </select>
        </div>
        <div class="col-md-2">
          <button type="submit" class="btn btn-outline-primary w-100">Фильтр</button>
        </div>
        <div class="col-md-2">
          <a href="/tasks" class="btn btn-outline-secondary w-100">Сброс</a>
        </div>
      </form>

      <!-- Просроченные -->
      <% if (overdue.length > 0) { %>
        <div class="mb-4">
          <h6 class="text-danger fw-semibold mb-2">
            <i class="bi bi-exclamation-triangle me-1"></i>Просроченные (<%= overdue.length %>)
          </h6>
          <% overdue.forEach(task => { %>
            <%- include('./task-card', { task, isOverdue: true }) %>
          <% }) %>
        </div>
      <% } %>

      <!-- Активные -->
      <h6 class="fw-semibold mb-2">Активные задачи (<%= active.length %>)</h6>
      <% if (active.length === 0) { %>
        <div class="text-center py-5">
          <i class="bi bi-check2-all display-4 text-success"></i>
          <p class="text-muted mt-2">Все задачи выполнены!</p>
        </div>
      <% } else { %>
        <% active.forEach(task => { %>
          <%- include('./task-card', { task, isOverdue: false }) %>
        <% }) %>
      <% } %>

    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
async function changeStatus(taskId, status) {
  const res = await fetch(`/tasks/${taskId}/status`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ status }),
  });
  if (res.ok) window.location.reload();
}
</script>
</body>
</html>