<!DOCTYPE html>
<html lang="ru">
<head><%- include('../partials/head') %></head>
<body>
<div class="app-layout">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/navbar') %>
    <div class="page-content">

      <div class="d-flex align-items-center mb-4">
        <a href="/tasks" class="btn btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
        <h5 class="fw-bold mb-0">Новая задача</h5>
      </div>

      <div class="stat-card" style="max-width:600px">
        <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

        <form action="/tasks" method="POST">
          <div class="row g-3">
            <div class="col-12">
              <label class="form-label">Название *</label>
              <input type="text" name="title" class="form-control" required />
            </div>
            <div class="col-12">
              <label class="form-label">Описание</label>
              <textarea name="description" class="form-control" rows="3"></textarea>
            </div>
            <div class="col-md-6">
              <label class="form-label">Клиент</label>
              <select name="client_id" class="form-select">
                <option value="">Без клиента</option>
                <% clients.forEach(c => { %>
                  <option value="<%= c.id %>" <%= selectedClientId === c.id ? 'selected' : '' %>><%= c.name %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Сделка</label>
              <select name="deal_id" class="form-select">
                <option value="">Без сделки</option>
                <% deals.forEach(d => { %>
                  <option value="<%= d.id %>" <%= selectedDealId === d.id ? 'selected' : '' %>><%= d.title %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Приоритет</label>
              <select name="priority" class="form-select">
                <option value="low">Низкий</option>
                <option value="medium" selected>Средний</option>
                <option value="high">Высокий</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Дедлайн</label>
              <input type="date" name="deadline" class="form-control" />
            </div>
            <div class="col-12">
              <button type="submit" class="btn btn-primary">Создать задачу</button>
              <a href="/tasks" class="btn btn-outline-secondary ms-2">Отмена</a>
            </div>
          </div>
        </form>
      </div>

    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>