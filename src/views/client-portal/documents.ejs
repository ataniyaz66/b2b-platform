<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Мои документы</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/main.css"/>
  <style>
    .portal-navbar { background: #1e1b4b; padding: 1rem 2rem; }
    .portal-navbar a, .portal-navbar span { color: rgba(255,255,255,.85); text-decoration: none; }
    .portal-nav-link { padding: .4rem .8rem; border-radius: 6px; transition: background .2s; }
    .portal-nav-link:hover, .portal-nav-link.active { background: rgba(255,255,255,.15); color: #fff !important; }
  </style>
</head>
<body style="background:#f8f9fa">
<nav class="portal-navbar d-flex align-items-center justify-content-between">
  <div class="d-flex align-items-center gap-4">
    <span class="fw-bold fs-5"><i class="bi bi-grid-fill me-2"></i>Личный кабинет</span>
    <div class="d-flex gap-1">
      <a href="/portal" class="portal-nav-link"><i class="bi bi-house me-1"></i>Главная</a>
      <a href="/portal/deals" class="portal-nav-link"><i class="bi bi-kanban me-1"></i>Сделки</a>
      <a href="/portal/invoices" class="portal-nav-link"><i class="bi bi-receipt me-1"></i>Счета</a>
      <a href="/portal/documents" class="portal-nav-link active"><i class="bi bi-file-earmark-text me-1"></i>Документы</a>
    </div>
  </div>
  <div class="d-flex align-items-center gap-3">
    <span class="small text-white-50"><%= user.company_name %></span>
    <form action="/auth/logout" method="POST" class="mb-0">
      <button class="btn btn-sm btn-outline-light">Выйти</button>
    </form>
  </div>
</nav>
<div class="container-lg py-4">

  <h5 class="fw-bold mb-4">Мои документы</h5>

  <% const typeMap = { contract: 'Договор', act: 'Акт', proposal: 'Предложение', other: 'Другое' } %>
  <% const typeBadge = { contract: 'primary', act: 'success', proposal: 'info', other: 'secondary' } %>

  <% if (documents.length === 0) { %>
    <div class="stat-card text-center py-5">
      <i class="bi bi-file-earmark-text display-4 text-muted"></i>
      <p class="text-muted mt-2">Документов пока нет</p>
    </div>
  <% } else { %>
    <% documents.forEach(doc => { %>
      <div class="stat-card mb-3 d-flex justify-content-between align-items-center">
        <div>
          <div class="fw-semibold"><%= doc.title %></div>
          <div class="text-muted small mt-1"><%= new Date(doc.createdAt).toLocaleDateString('ru-RU') %></div>
        </div>
        <div class="d-flex align-items-center gap-2">
          <span class="badge bg-<%= typeBadge[doc.type] %>"><%= typeMap[doc.type] %></span>
          <% if (doc.file_path) { %>
            <a href="/uploads/<%= doc.file_path %>" target="_blank" class="btn btn-sm btn-outline-primary">
              <i class="bi bi-download"></i>
            </a>
          <% } %>
        </div>
      </div>
    <% }) %>
  <% } %>

</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>