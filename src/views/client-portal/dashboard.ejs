<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Личный кабинет</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/main.css"/>
  <style>
    .portal-navbar { background: #1e1b4b; padding: 1rem 2rem; }
    .portal-navbar a, .portal-navbar span { color: rgba(255,255,255,.85); text-decoration: none; }
    .portal-nav-link { padding: .4rem .8rem; border-radius: 6px; transition: background .2s; }
    .portal-nav-link:hover, .portal-nav-link.active { background: rgba(255,255,255,.15); color: #fff !important; }
  </style>
</head>
<body style="background:#f8f9fa">
<nav class="portal-navbar d-flex align-items-center justify-content-between">
  <div class="d-flex align-items-center gap-4">
    <span class="fw-bold fs-5"><i class="bi bi-grid-fill me-2"></i>Личный кабинет</span>
    <div class="d-flex gap-1">
      <a href="/portal" class="portal-nav-link active"><i class="bi bi-house me-1"></i>Главная</a>
      <a href="/portal/deals" class="portal-nav-link"><i class="bi bi-kanban me-1"></i>Сделки</a>
      <a href="/portal/invoices" class="portal-nav-link"><i class="bi bi-receipt me-1"></i>Счета</a>
      <a href="/portal/documents" class="portal-nav-link"><i class="bi bi-file-earmark-text me-1"></i>Документы</a>
    </div>
  </div>
  <div class="d-flex align-items-center gap-3">
    <span class="small text-white-50"><%= user.company_name %></span>
    <form action="/auth/logout" method="POST" class="mb-0">
      <button class="btn btn-sm btn-outline-light">Выйти</button>
    </form>
  </div>
</nav>
<div class="container-lg py-4">

  <h5 class="fw-bold mb-4">Добро пожаловать, <%= user.company_name %>!</h5>

  <% if (!client) { %>
    <div class="alert alert-info">
      <i class="bi bi-info-circle me-2"></i>
      Ваш аккаунт ещё не привязан к профилю клиента. Обратитесь к менеджеру.
    </div>
  <% } else { %>

    <div class="row g-3 mb-4">
      <div class="col-md-4">
        <div class="stat-card text-center">
          <div class="text-muted small mb-1">Активных сделок</div>
          <div class="fs-3 fw-bold text-primary">
            <%= deals.filter(d => !['won','lost'].includes(d.stage)).length %>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="stat-card text-center">
          <div class="text-muted small mb-1">Счетов к оплате</div>
          <div class="fs-3 fw-bold text-warning">
            <%= invoices.filter(i => i.status === 'issued').length %>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="stat-card text-center">
          <div class="text-muted small mb-1">Просроченных счетов</div>
          <div class="fs-3 fw-bold text-danger">
            <%= invoices.filter(i => i.status === 'overdue').length %>
          </div>
        </div>
      </div>
    </div>

    <!-- Последние счета -->
    <div class="stat-card mb-3">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="fw-semibold mb-0">Последние счета</h6>
        <a href="/portal/invoices" class="btn btn-sm btn-outline-primary">Все счета</a>
      </div>
      <% if (invoices.length === 0) { %>
        <p class="text-muted">Счетов пока нет</p>
      <% } else { %>
        <% const invBadge = { issued: 'primary', pending: 'warning', paid: 'success', overdue: 'danger' } %>
        <% const invMap = { issued: 'Выставлен', pending: 'Ожидает проверки', paid: 'Оплачен', overdue: 'Просрочен' } %>
        <% invoices.slice(0,3).forEach(inv => { %>
          <div class="d-flex justify-content-between align-items-center p-2 border rounded mb-2">
            <div>
              <div class="fw-semibold"><%= inv.amount %> <%= inv.currency %></div>
              <div class="text-muted small">
                <%= inv.due_date ? 'До ' + new Date(inv.due_date).toLocaleDateString('ru-RU') : '' %>
              </div>
            </div>
            <span class="badge bg-<%= invBadge[inv.status] %>"><%= invMap[inv.status] %></span>
          </div>
        <% }) %>
      <% } %>
    </div>

    <!-- Последние сделки -->
    <div class="stat-card">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="fw-semibold mb-0">Мои сделки</h6>
        <a href="/portal/deals" class="btn btn-sm btn-outline-primary">Все сделки</a>
      </div>
      <% if (deals.length === 0) { %>
        <p class="text-muted">Сделок пока нет</p>
      <% } else { %>
        <% const stageBadge = { new: 'secondary', negotiation: 'primary', proposal: 'info', won: 'success', lost: 'danger' } %>
        <% const stageMap = { new: 'Новая', negotiation: 'Переговоры', proposal: 'Предложение', won: 'Выиграна', lost: 'Проиграна' } %>
        <% deals.slice(0,3).forEach(deal => { %>
          <div class="d-flex justify-content-between align-items-center p-2 border rounded mb-2">
            <span class="fw-semibold"><%= deal.title %></span>
            <div>
              <span class="me-2 text-muted"><%= deal.amount %> <%= deal.currency %></span>
              <span class="badge bg-<%= stageBadge[deal.stage] %>"><%= stageMap[deal.stage] %></span>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>

  <% } %>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>