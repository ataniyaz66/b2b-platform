<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Мои счета</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/main.css"/>
  <style>
    .portal-navbar { background: #1e1b4b; padding: 1rem 2rem; }
    .portal-navbar a, .portal-navbar span { color: rgba(255,255,255,.85); text-decoration: none; }
    .portal-nav-link { padding: .4rem .8rem; border-radius: 6px; transition: background .2s; }
    .portal-nav-link:hover, .portal-nav-link.active { background: rgba(255,255,255,.15); color: #fff !important; }
  </style>
</head>
<body style="background:#f8f9fa">
<nav class="portal-navbar d-flex align-items-center justify-content-between">
  <div class="d-flex align-items-center gap-4">
    <span class="fw-bold fs-5"><i class="bi bi-grid-fill me-2"></i>Личный кабинет</span>
    <div class="d-flex gap-1">
      <a href="/portal" class="portal-nav-link"><i class="bi bi-house me-1"></i>Главная</a>
      <a href="/portal/deals" class="portal-nav-link"><i class="bi bi-kanban me-1"></i>Сделки</a>
      <a href="/portal/invoices" class="portal-nav-link active"><i class="bi bi-receipt me-1"></i>Счета</a>
      <a href="/portal/documents" class="portal-nav-link"><i class="bi bi-file-earmark-text me-1"></i>Документы</a>
    </div>
  </div>
  <div class="d-flex align-items-center gap-3">
    <span class="small text-white-50"><%= user.company_name %></span>
    <form action="/auth/logout" method="POST" class="mb-0">
      <button class="btn btn-sm btn-outline-light">Выйти</button>
    </form>
  </div>
</nav>
<div class="container-lg py-4">

  <h5 class="fw-bold mb-4">Мои счета</h5>

  <% const invBadge = { issued: 'primary', pending: 'warning', paid: 'success', overdue: 'danger' } %>
  <% const invMap = { issued: 'Выставлен', pending: 'Ожидает проверки', paid: 'Оплачен', overdue: 'Просрочен' } %>

  <% if (invoices.length === 0) { %>
    <div class="stat-card text-center py-5">
      <i class="bi bi-receipt display-4 text-muted"></i>
      <p class="text-muted mt-2">Счетов пока нет</p>
    </div>
  <% } else { %>
    <% invoices.forEach(inv => { %>
      <div class="stat-card mb-3">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <div class="fs-5 fw-bold"><%= inv.amount %> <%= inv.currency %></div>
            <% if (inv.description) { %>
              <div class="text-muted small mt-1"><%= inv.description %></div>
            <% } %>
            <% if (inv.due_date) { %>
              <div class="text-muted small mt-1">
                <i class="bi bi-calendar me-1"></i>Срок: <%= new Date(inv.due_date).toLocaleDateString('ru-RU') %>
              </div>
            <% } %>
          </div>
          <span class="badge bg-<%= invBadge[inv.status] %> fs-6"><%= invMap[inv.status] %></span>
        </div>

        <% if (inv.status === 'issued') { %>
          <div class="mt-3 border-top pt-3">
            <p class="text-muted small mb-2">Подтвердите оплату — прикрепите скриншот или чек:</p>
            <div class="d-flex gap-2 align-items-center">
              <input type="file" class="form-control form-control-sm" id="file-<%= inv.id %>" accept=".jpg,.png,.pdf" style="max-width:300px"/>
              <button onclick="confirmPayment('<%= inv.id %>')" class="btn btn-sm btn-success">
                <i class="bi bi-check-circle me-1"></i>Подтвердить оплату
              </button>
            </div>
          </div>
        <% } %>

        <% if (inv.status === 'pending') { %>
          <div class="alert alert-warning mt-3 mb-0 py-2">
            <i class="bi bi-clock me-2"></i>Ваше подтверждение получено. Ожидаем проверку менеджером.
          </div>
        <% } %>
      </div>
    <% }) %>
  <% } %>

</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
async function confirmPayment(invoiceId) {
  const fileInput = document.getElementById(`file-${invoiceId}`);
  const formData = new FormData();
  if (fileInput.files[0]) formData.append('file', fileInput.files[0]);

  const res = await fetch(`/portal/invoices/${invoiceId}/confirm`, {
    method: 'POST',
    body: formData,
  });
  if (res.ok) window.location.reload();
  else alert('Ошибка подтверждения');
}
</script>
</body>
</html>