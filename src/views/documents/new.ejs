<!DOCTYPE html>
<html lang="ru">
<head><%- include('../partials/head') %></head>
<body>
<div class="app-layout">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/navbar') %>
    <div class="page-content">

      <div class="d-flex align-items-center mb-4">
        <a href="/documents" class="btn btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
        <h5 class="fw-bold mb-0">Новый документ</h5>
      </div>

      <div class="stat-card" style="max-width:700px">
        <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

        <form action="/documents" method="POST" enctype="multipart/form-data">
          <div class="row g-3">
            <div class="col-md-8">
              <label class="form-label">Название *</label>
              <input type="text" name="title" class="form-control" required />
            </div>
            <div class="col-md-4">
              <label class="form-label">Тип</label>
              <select name="type" class="form-select">
                <option value="contract">Договор</option>
                <option value="act">Акт</option>
                <option value="proposal">Предложение</option>
                <option value="other">Другое</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Клиент</label>
              <select name="client_id" class="form-select">
                <option value="">Без клиента</option>
                <% clients.forEach(c => { %>
                  <option value="<%= c.id %>"><%= c.name %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Сделка</label>
              <select name="deal_id" class="form-select">
                <option value="">Без сделки</option>
                <% deals.forEach(d => { %>
                  <option value="<%= d.id %>"><%= d.title %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-12">
              <label class="form-label">Содержание документа</label>
              <textarea name="content" class="form-control" rows="8"
                placeholder="Текст договора, акта или предложения — будет включён в PDF..."></textarea>
            </div>
            <div class="col-12">
              <label class="form-label">Или прикрепить готовый файл</label>
              <input type="file" name="file" class="form-control" accept=".pdf,.doc,.docx,.png,.jpg" />
              <div class="form-text">Если загружаете файл, текст содержания не обязателен</div>
            </div>
            <div class="col-12">
              <button type="submit" class="btn btn-primary">Создать документ</button>
              <a href="/documents" class="btn btn-outline-secondary ms-2">Отмена</a>
            </div>
          </div>
        </form>
      </div>

    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>