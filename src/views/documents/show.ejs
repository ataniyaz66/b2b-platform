<!DOCTYPE html>
<html lang="ru">
<head><%- include('../partials/head') %></head>
<body>
<div class="app-layout">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/navbar') %>
    <div class="page-content">

      <div class="d-flex align-items-center justify-content-between mb-4">
        <div class="d-flex align-items-center">
          <a href="/documents" class="btn btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
          <h5 class="fw-bold mb-0"><%= document.title %></h5>
        </div>
        <div class="d-flex gap-2">
          <a href="/documents/<%= document.id %>/pdf" class="btn btn-danger">
            <i class="bi bi-file-pdf me-1"></i>Скачать PDF
          </a>
          <form action="/documents/<%= document.id %>/delete" method="POST"
            onsubmit="return confirm('Удалить документ?')">
            <button type="submit" class="btn btn-outline-danger"><i class="bi bi-trash"></i></button>
          </form>
        </div>
      </div>

      <div class="row g-3">
        <div class="col-md-4">
          <div class="stat-card">
            <h6 class="fw-semibold mb-3">Информация</h6>
            <% const typeMap = { contract: 'Договор', act: 'Акт', proposal: 'Предложение', other: 'Другое' } %>
            <% const typeBadge = { contract: 'primary', act: 'success', proposal: 'info', other: 'secondary' } %>
            <div class="mb-2">
              <span class="text-muted small">Тип:</span><br/>
              <span class="badge bg-<%= typeBadge[document.type] %>"><%= typeMap[document.type] %></span>
            </div>
            <% if (document.client) { %>
              <div class="mb-2">
                <span class="text-muted small">Клиент:</span><br/>
                <a href="/clients/<%= document.client.id %>"><%= document.client.name %></a>
              </div>
            <% } %>
            <% if (document.deal) { %>
              <div class="mb-2">
                <span class="text-muted small">Сделка:</span><br/>
                <a href="/deals/<%= document.deal.id %>"><%= document.deal.title %></a>
              </div>
            <% } %>
            <div class="mb-2">
              <span class="text-muted small">Создан:</span><br/>
              <%= new Date(document.createdAt).toLocaleDateString('ru-RU') %>
            </div>
            <% if (document.file_path) { %>
              <div class="mt-3">
                <a href="/uploads/<%= document.file_path %>" target="_blank" class="btn btn-sm btn-outline-primary w-100">
                  <i class="bi bi-paperclip me-1"></i>Открыть файл
                </a>
              </div>
            <% } %>
          </div>
        </div>

        <div class="col-md-8">
          <div class="stat-card">
            <h6 class="fw-semibold mb-3">Содержание</h6>
            <% if (document.content) { %>
              <div style="white-space: pre-wrap; font-family: 'Courier New', monospace; font-size: .9rem; line-height: 1.6;">
                <%= document.content %>
              </div>
            <% } else { %>
              <p class="text-muted">Текстового содержания нет. Документ является прикреплённым файлом.</p>
            <% } %>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>