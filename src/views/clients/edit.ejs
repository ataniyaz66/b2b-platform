<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Редактировать клиента — B2B CRM</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/main.css"/>
</head>
<body>
<div class="app-layout">

  <div class="sidebar d-flex flex-column p-3">
    <a href="/dashboard" class="sidebar-brand mb-4">
      <i class="bi bi-grid-fill me-2"></i>B2B CRM
    </a>
    <nav class="nav flex-column gap-1">
      <a href="/dashboard" class="nav-link"><i class="bi bi-speedometer2 me-2"></i>Дашборд</a>
      <a href="/clients" class="nav-link active"><i class="bi bi-people me-2"></i>Клиенты</a>
      <a href="/deals" class="nav-link"><i class="bi bi-kanban me-2"></i>Сделки</a>
      <a href="/invoices" class="nav-link"><i class="bi bi-receipt me-2"></i>Счета</a>
      <a href="/documents" class="nav-link"><i class="bi bi-file-earmark-text me-2"></i>Документы</a>
      <a href="/tasks" class="nav-link"><i class="bi bi-check2-square me-2"></i>Задачи</a>
      <a href="/reports" class="nav-link"><i class="bi bi-bar-chart me-2"></i>Отчёты</a>
    </nav>
    <div class="mt-auto">
      <form action="/auth/logout" method="POST">
        <button class="btn btn-outline-secondary w-100">
          <i class="bi bi-box-arrow-left me-2"></i>Выйти
        </button>
      </form>
    </div>
  </div>

  <div class="main-content">
    <nav class="top-navbar d-flex align-items-center justify-content-between px-4">
      <span class="fw-semibold text-muted">Редактировать клиента</span>
      <span class="text-muted small"><%- user.company_name %></span>
    </nav>

    <div class="page-content">

      <div class="d-flex align-items-center mb-4">
        <a href="/clients/<%- client.id %>" class="btn btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
        <h5 class="fw-bold mb-0">Редактировать: <%- client.name %></h5>
      </div>

      <div class="stat-card" style="max-width:700px">
        <% if (error) { %>
          <div class="alert alert-danger"><%- error %></div>
        <% } %>

        <form action="/clients/<%- client.id %>/update" method="POST">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Название компании *</label>
              <input type="text" name="name" class="form-control" value="<%- client.name %>" required />
            </div>
            <div class="col-md-6">
              <label class="form-label">Контактное лицо</label>
              <input type="text" name="contact_person" class="form-control" value="<%- client.contact_person || '' %>" />
            </div>
            <div class="col-md-6">
              <label class="form-label">Email</label>
              <input type="email" name="email" class="form-control" value="<%- client.email || '' %>" />
            </div>
            <div class="col-md-6">
              <label class="form-label">Телефон</label>
              <input type="text" name="phone" class="form-control" value="<%- client.phone || '' %>" />
            </div>
            <div class="col-md-8">
              <label class="form-label">Адрес</label>
              <input type="text" name="address" class="form-control" value="<%- client.address || '' %>" />
            </div>
            <div class="col-md-4">
              <label class="form-label">Страна</label>
              <input type="text" name="country" class="form-control" value="<%- client.country || '' %>" />
            </div>
            <div class="col-md-4">
              <label class="form-label">Валюта</label>
              <select name="currency" class="form-select">
                <option value="USD" <% if(client.currency==='USD'){%>selected<%}%>>USD</option>
                <option value="EUR" <% if(client.currency==='EUR'){%>selected<%}%>>EUR</option>
                <option value="RUB" <% if(client.currency==='RUB'){%>selected<%}%>>RUB</option>
                <option value="KZT" <% if(client.currency==='KZT'){%>selected<%}%>>KZT</option>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label">Статус</label>
              <select name="status" class="form-select">
                <option value="active" <% if(client.status==='active'){%>selected<%}%>>Активный</option>
                <option value="lead" <% if(client.status==='lead'){%>selected<%}%>>Лид</option>
                <option value="inactive" <% if(client.status==='inactive'){%>selected<%}%>>Неактивный</option>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label">Теги</label>
              <input type="text" name="tags" class="form-control" value="<%- (client.tags || []).join(', ') %>" />
              <div class="form-text">Через запятую</div>
            </div>
            <div class="col-12">
              <label class="form-label">Заметки</label>
              <textarea name="notes" class="form-control" rows="3"><%- client.notes || '' %></textarea>
            </div>
            <div class="col-12 d-flex justify-content-between">
              <div>
                <button type="submit" class="btn btn-primary">Сохранить</button>
                <a href="/clients/<%- client.id %>" class="btn btn-outline-secondary ms-2">Отмена</a>
              </div>
              <button type="button" class="btn btn-outline-danger"
                onclick="if(confirm('Удалить клиента?')) document.getElementById('delete-form').submit()">
                <i class="bi bi-trash"></i> Удалить
              </button>
            </div>
          </div>
        </form>

        <form id="delete-form" action="/clients/<%- client.id %>/delete" method="POST"></form>

      </div>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>