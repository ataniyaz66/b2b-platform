<!DOCTYPE html>
<html lang="ru">
<head><%- include('../partials/head') %></head>
<body>
<div class="app-layout">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/navbar') %>
    <div class="page-content">

      <% if (successMsg) { %>
        <div class="alert alert-success alert-dismissible">
          <i class="bi bi-check-circle me-2"></i>
          Доступ создан! Пароль: <strong><%= successMsg %></strong> — отправлен на email клиента.
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>
      <% if (errorMsg === 'no_email') { %>
        <div class="alert alert-danger">У клиента не указан email — доступ создать невозможно.</div>
      <% } %>
      <% if (errorMsg === 'already_exists') { %>
        <div class="alert alert-warning">Доступ для этого клиента уже существует.</div>
      <% } %>

      <div class="d-flex align-items-center justify-content-between mb-4">
        <div class="d-flex align-items-center">
          <a href="/clients" class="btn btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
          <h5 class="fw-bold mb-0"><%= client.name %></h5>
        </div>
        <div class="d-flex gap-2">
          <a href="/clients/<%= client.id %>/edit" class="btn btn-outline-primary">
            <i class="bi bi-pencil me-1"></i>Редактировать
          </a>
          <% if (!hasAccess) { %>
            <form action="/clients/<%= client.id %>/create-access" method="POST">
              <button type="submit" class="btn btn-outline-success"
                onclick="return confirm('Создать доступ в личный кабинет?')">
                <i class="bi bi-person-plus me-1"></i>Создать доступ
              </button>
            </form>
          <% } else { %>
            <span class="btn btn-success disabled">
              <i class="bi bi-person-check me-1"></i>Доступ выдан
            </span>
          <% } %>
        </div>
      </div>

      <div class="row g-3">
        <div class="col-md-4">
          <div class="stat-card">
            <h6 class="fw-semibold mb-3">Информация</h6>
            <div class="mb-2"><span class="text-muted small">Контакт:</span><br/><%= client.contact_person || '—' %></div>
            <div class="mb-2"><span class="text-muted small">Email:</span><br/>
              <% if (client.email) { %><a href="mailto:<%= client.email %>"><%= client.email %></a><% } else { %>—<% } %>
            </div>
            <div class="mb-2"><span class="text-muted small">Телефон:</span><br/><%= client.phone || '—' %></div>
            <div class="mb-2"><span class="text-muted small">Адрес:</span><br/><%= client.address || '—' %></div>
            <div class="mb-2"><span class="text-muted small">Страна:</span><br/><%= client.country || '—' %></div>
            <div class="mb-2"><span class="text-muted small">Валюта:</span><br/><%= client.currency %></div>
            <div class="mb-2">
              <span class="text-muted small">Статус:</span><br/>
              <% const statusMap = { active: ['success', 'Активный'], inactive: ['secondary', 'Неактивный'], lead: ['warning', 'Лид'] } %>
              <span class="badge bg-<%= statusMap[client.status][0] %>"><%= statusMap[client.status][1] %></span>
            </div>
            <% if (client.tags && client.tags.length > 0) { %>
              <div class="mb-2">
                <span class="text-muted small">Теги:</span><br/>
                <% client.tags.forEach(tag => { %>
                  <span class="badge bg-light text-dark border me-1"><%= tag %></span>
                <% }) %>
              </div>
            <% } %>
            <% if (client.notes) { %>
              <div class="mt-3">
                <span class="text-muted small">Заметки:</span>
                <p class="mt-1"><%= client.notes %></p>
              </div>
            <% } %>
          </div>
        </div>

        <div class="col-md-8">
          <div class="stat-card mb-3">
            <div class="d-flex justify-content-between align-items-center mb-3">
              <h6 class="fw-semibold mb-0">Сделки (<%= client.deals.length %>)</h6>
              <a href="/deals/new?client_id=<%= client.id %>" class="btn btn-sm btn-outline-primary">+ Сделка</a>
            </div>
            <% if (client.deals.length === 0) { %>
              <p class="text-muted">Сделок нет</p>
            <% } else { %>
              <% const stageBadge = { new: 'secondary', negotiation: 'primary', proposal: 'info', won: 'success', lost: 'danger' } %>
              <% const stageMap = { new: 'Новая', negotiation: 'Переговоры', proposal: 'Предложение', won: 'Выиграна', lost: 'Проиграна' } %>
              <% client.deals.forEach(deal => { %>
                <div class="d-flex justify-content-between align-items-center p-2 border rounded mb-2">
                  <a href="/deals/<%= deal.id %>" class="text-decoration-none fw-semibold"><%= deal.title %></a>
                  <div>
                    <span class="me-3"><%= deal.amount %> <%= deal.currency %></span>
                    <span class="badge bg-<%= stageBadge[deal.stage] %>"><%= stageMap[deal.stage] %></span>
                  </div>
                </div>
              <% }) %>
            <% } %>
          </div>

          <div class="stat-card mb-3">
            <div class="d-flex justify-content-between align-items-center mb-3">
              <h6 class="fw-semibold mb-0">Счета (<%= client.invoices.length %>)</h6>
              <a href="/invoices/new?client_id=<%= client.id %>" class="btn btn-sm btn-outline-primary">+ Счёт</a>
            </div>
            <% if (client.invoices.length === 0) { %>
              <p class="text-muted">Счетов нет</p>
            <% } else { %>
              <% const invBadge = { issued: 'primary', pending: 'warning', paid: 'success', overdue: 'danger' } %>
              <% const invMap = { issued: 'Выставлен', pending: 'Ожидает', paid: 'Оплачен', overdue: 'Просрочен' } %>
              <% client.invoices.forEach(inv => { %>
                <div class="d-flex justify-content-between align-items-center p-2 border rounded mb-2">
                  <a href="/invoices/<%= inv.id %>" class="text-decoration-none"><%= inv.amount %> <%= inv.currency %></a>
                  <span class="badge bg-<%= invBadge[inv.status] %>"><%= invMap[inv.status] %></span>
                </div>
              <% }) %>
            <% } %>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>