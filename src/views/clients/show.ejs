<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%- client.name %> — B2B CRM</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/main.css"/>
</head>
<body>
<div class="app-layout">

  <div class="sidebar d-flex flex-column p-3">
    <a href="/dashboard" class="sidebar-brand mb-4">
      <i class="bi bi-grid-fill me-2"></i>B2B CRM
    </a>
    <nav class="nav flex-column gap-1">
      <a href="/dashboard" class="nav-link">
        <i class="bi bi-speedometer2 me-2"></i>Дашборд
      </a>
      <a href="/clients" class="nav-link active">
        <i class="bi bi-people me-2"></i>Клиенты
      </a>
      <a href="/deals" class="nav-link">
        <i class="bi bi-kanban me-2"></i>Сделки
      </a>
      <a href="/invoices" class="nav-link">
        <i class="bi bi-receipt me-2"></i>Счета
      </a>
      <a href="/documents" class="nav-link">
        <i class="bi bi-file-earmark-text me-2"></i>Документы
      </a>
      <a href="/tasks" class="nav-link">
        <i class="bi bi-check2-square me-2"></i>Задачи
      </a>
      <a href="/reports" class="nav-link">
        <i class="bi bi-bar-chart me-2"></i>Отчёты
      </a>
    </nav>
    <div class="mt-auto">
      <form action="/auth/logout" method="POST">
        <button class="btn btn-outline-secondary w-100">
          <i class="bi bi-box-arrow-left me-2"></i>Выйти
        </button>
      </form>
    </div>
  </div>

  <div class="main-content">
    <nav class="top-navbar d-flex align-items-center justify-content-between px-4">
      <span class="fw-semibold text-muted"><%- client.name %></span>
      <div class="d-flex align-items-center gap-3">
        <a href="/notifications" class="position-relative text-dark">
          <i class="bi bi-bell fs-5"></i>
          <% if (unreadCount > 0) { %>
            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
              <%- unreadCount %>
            </span>
          <% } %>
        </a>
        <span class="text-muted small"><%- user.company_name %></span>
      </div>
    </nav>

    <div class="page-content">

      <% if (successMsg) { %>
        <div class="alert alert-success alert-dismissible">
          <i class="bi bi-check-circle me-2"></i>
          Доступ создан! Пароль: <strong><%- successMsg %></strong> — отправлен на email клиента.
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>
      <% if (errorMsg === 'no_email') { %>
        <div class="alert alert-danger">У клиента не указан email — доступ создать невозможно.</div>
      <% } %>
      <% if (errorMsg === 'already_exists') { %>
        <div class="alert alert-warning">Доступ для этого клиента уже существует.</div>
      <% } %>

      <div class="d-flex align-items-center justify-content-between mb-4">
        <div class="d-flex align-items-center">
          <a href="/clients" class="btn btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
          <h5 class="fw-bold mb-0"><%- client.name %></h5>
        </div>
        <div class="d-flex gap-2">
          <a href="/clients/<%- client.id %>/edit" class="btn btn-outline-primary">
            <i class="bi bi-pencil me-1"></i>Редактировать
          </a>
          <% if (!hasAccess) { %>
            <form action="/clients/<%- client.id %>/create-access" method="POST">
              <button type="submit" class="btn btn-outline-success"
                onclick="return confirm('Создать доступ в личный кабинет?')">
                <i class="bi bi-person-plus me-1"></i>Создать доступ
              </button>
            </form>
          <% } else { %>
            <span class="btn btn-success disabled">
              <i class="bi bi-person-check me-1"></i>Доступ выдан
            </span>
          <% } %>
        </div>
      </div>

      <div class="row g-3">
        <div class="col-md-4">
          <div class="stat-card">
            <h6 class="fw-semibold mb-3">Информация</h6>
            <div class="mb-2">
              <span class="text-muted small">Контакт:</span><br/>
              <%- client.contact_person || '—' %>
            </div>
            <div class="mb-2">
              <span class="text-muted small">Email:</span><br/>
              <% if (client.email) { %>
                <a href="mailto:<%- client.email %>"><%- client.email %></a>
              <% } else { %>—<% } %>
            </div>
            <div class="mb-2">
              <span class="text-muted small">Телефон:</span><br/>
              <%- client.phone || '—' %>
            </div>
            <div class="mb-2">
              <span class="text-muted small">Адрес:</span><br/>
              <%- client.address || '—' %>
            </div>
            <div class="mb-2">
              <span class="text-muted small">Страна:</span><br/>
              <%- client.country || '—' %>
            </div>
            <div class="mb-2">
              <span class="text-muted small">Валюта:</span><br/>
              <%- client.currency %>
            </div>
            <div class="mb-2">
              <span class="text-muted small">Статус:</span><br/>
              <% if (client.status === 'active') { %>
                <span class="badge bg-success">Активный</span>
              <% } else if (client.status === 'inactive') { %>
                <span class="badge bg-secondary">Неактивный</span>
              <% } else { %>
                <span class="badge bg-warning">Лид</span>
              <% } %>
            </div>
            <% if (client.tags && client.tags.length > 0) { %>
              <div class="mb-2">
                <span class="text-muted small">Теги:</span><br/>
                <% client.tags.forEach(function(tag) { %>
                  <span class="badge bg-light text-dark border me-1"><%- tag %></span>
                <% }); %>
              </div>
            <% } %>
            <% if (client.notes) { %>
              <div class="mt-3">
                <span class="text-muted small">Заметки:</span>
                <p class="mt-1"><%- client.notes %></p>
              </div>
            <% } %>
          </div>
        </div>

        <div class="col-md-8">
          <div class="stat-card mb-3">
            <div class="d-flex justify-content-between align-items-center mb-3">
              <h6 class="fw-semibold mb-0">Сделки (<%- client.deals.length %>)</h6>
              <a href="/deals/new?client_id=<%- client.id %>" class="btn btn-sm btn-outline-primary">+ Сделка</a>
            </div>
            <% if (client.deals.length === 0) { %>
              <p class="text-muted">Сделок нет</p>
            <% } else { %>
              <% client.deals.forEach(function(deal) { %>
                <div class="d-flex justify-content-between align-items-center p-2 border rounded mb-2">
                  <a href="/deals/<%- deal.id %>" class="text-decoration-none fw-semibold"><%- deal.title %></a>
                  <div>
                    <span class="me-3"><%- deal.amount %> <%- deal.currency %></span>
                    <% if (deal.stage === 'won') { %>
                      <span class="badge bg-success">Выиграна</span>
                    <% } else if (deal.stage === 'lost') { %>
                      <span class="badge bg-danger">Проиграна</span>
                    <% } else if (deal.stage === 'negotiation') { %>
                      <span class="badge bg-primary">Переговоры</span>
                    <% } else if (deal.stage === 'proposal') { %>
                      <span class="badge bg-info">Предложение</span>
                    <% } else { %>
                      <span class="badge bg-secondary">Новая</span>
                    <% } %>
                  </div>
                </div>
              <% }); %>
            <% } %>
          </div>

          <div class="stat-card mb-3">
            <div class="d-flex justify-content-between align-items-center mb-3">
              <h6 class="fw-semibold mb-0">Счета (<%- client.invoices.length %>)</h6>
              <a href="/invoices/new?client_id=<%- client.id %>" class="btn btn-sm btn-outline-primary">+ Счёт</a>
            </div>
            <% if (client.invoices.length === 0) { %>
              <p class="text-muted">Счетов нет</p>
            <% } else { %>
              <% client.invoices.forEach(function(inv) { %>
                <div class="d-flex justify-content-between align-items-center p-2 border rounded mb-2">
                  <a href="/invoices/<%- inv.id %>" class="text-decoration-none"><%- inv.amount %> <%- inv.currency %></a>
                  <% if (inv.status === 'paid') { %>
                    <span class="badge bg-success">Оплачен</span>
                  <% } else if (inv.status === 'overdue') { %>
                    <span class="badge bg-danger">Просрочен</span>
                  <% } else if (inv.status === 'pending') { %>
                    <span class="badge bg-warning">Ожидает</span>
                  <% } else { %>
                    <span class="badge bg-primary">Выставлен</span>
                  <% } %>
                </div>
              <% }); %>
            <% } %>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>