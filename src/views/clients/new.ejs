<!DOCTYPE html>
<html lang="ru">
<head><%- include('../partials/head') %></head>
<body>
<div class="app-layout">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/navbar') %>
    <div class="page-content">

      <div class="d-flex align-items-center mb-4">
        <a href="/clients" class="btn btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
        <h5 class="fw-bold mb-0">Новый клиент</h5>
      </div>

      <div class="stat-card" style="max-width:700px">
        <% if (error) { %>
          <div class="alert alert-danger"><%= error %></div>
        <% } %>

        <form action="/clients" method="POST">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Название компании *</label>
              <input type="text" name="name" class="form-control" required />
            </div>
            <div class="col-md-6">
              <label class="form-label">Контактное лицо</label>
              <input type="text" name="contact_person" class="form-control" />
            </div>
            <div class="col-md-6">
              <label class="form-label">Email</label>
              <input type="email" name="email" class="form-control" />
            </div>
            <div class="col-md-6">
              <label class="form-label">Телефон</label>
              <input type="text" name="phone" class="form-control" />
            </div>
            <div class="col-md-8">
              <label class="form-label">Адрес</label>
              <input type="text" name="address" class="form-control" />
            </div>
            <div class="col-md-4">
              <label class="form-label">Страна</label>
              <input type="text" name="country" class="form-control" />
            </div>
            <div class="col-md-4">
              <label class="form-label">Валюта</label>
              <select name="currency" class="form-select">
                <option value="USD">USD</option>
                <option value="EUR">EUR</option>
                <option value="RUB">RUB</option>
                <option value="KZT">KZT</option>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label">Статус</label>
              <select name="status" class="form-select">
                <option value="active">Активный</option>
                <option value="lead">Лид</option>
                <option value="inactive">Неактивный</option>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label">Теги</label>
              <input type="text" name="tags" class="form-control" placeholder="VIP, партнёр, лид" />
              <div class="form-text">Через запятую</div>
            </div>
            <div class="col-12">
              <label class="form-label">Заметки</label>
              <textarea name="notes" class="form-control" rows="3"></textarea>
            </div>
            <div class="col-12">
              <button type="submit" class="btn btn-primary">Создать клиента</button>
              <a href="/clients" class="btn btn-outline-secondary ms-2">Отмена</a>
            </div>
          </div>
        </form>
      </div>

    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>