<!DOCTYPE html>
<html lang="ru">
<head><%- include('../partials/head') %></head>
<body>
<div class="app-layout">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/navbar') %>
    <div class="page-content">

      <div class="d-flex align-items-center mb-4">
        <a href="/deals/<%= deal.id %>" class="btn btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
        <h5 class="fw-bold mb-0">Редактировать сделку</h5>
      </div>

      <div class="stat-card" style="max-width:600px">
        <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

        <form action="/deals/<%= deal.id %>/update" method="POST">
          <div class="row g-3">
            <div class="col-12">
              <label class="form-label">Название *</label>
              <input type="text" name="title" class="form-control" value="<%= deal.title %>" required />
            </div>
            <div class="col-12">
              <label class="form-label">Клиент *</label>
              <select name="client_id" class="form-select" required>
                <% clients.forEach(c => { %>
                  <option value="<%= c.id %>" <%= deal.client_id === c.id ? 'selected' : '' %>><%= c.name %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Сумма</label>
              <input type="number" name="amount" class="form-control" value="<%= deal.amount %>" />
            </div>
            <div class="col-md-6">
              <label class="form-label">Валюта</label>
              <select name="currency" class="form-select">
                <option value="USD" <%= deal.currency === 'USD' ? 'selected' : '' %>>USD</option>
                <option value="EUR" <%= deal.currency === 'EUR' ? 'selected' : '' %>>EUR</option>
                <option value="RUB" <%= deal.currency === 'RUB' ? 'selected' : '' %>>RUB</option>
                <option value="KZT" <%= deal.currency === 'KZT' ? 'selected' : '' %>>KZT</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Стадия</label>
              <select name="stage" class="form-select">
                <option value="new" <%= deal.stage === 'new' ? 'selected' : '' %>>Новая</option>
                <option value="negotiation" <%= deal.stage === 'negotiation' ? 'selected' : '' %>>Переговоры</option>
                <option value="proposal" <%= deal.stage === 'proposal' ? 'selected' : '' %>>Предложение</option>
                <option value="won" <%= deal.stage === 'won' ? 'selected' : '' %>>Выиграна</option>
                <option value="lost" <%= deal.stage === 'lost' ? 'selected' : '' %>>Проиграна</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Дедлайн</label>
              <input type="date" name="deadline" class="form-control" value="<%= deal.deadline ? new Date(deal.deadline).toISOString().split('T')[0] : '' %>" />
            </div>
            <div class="col-12 d-flex justify-content-between">
              <div>
                <button type="submit" class="btn btn-primary">Сохранить</button>
                <a href="/deals/<%= deal.id %>" class="btn btn-outline-secondary ms-2">Отмена</a>
              </div>
              <form action="/deals/<%= deal.id %>/delete" method="POST" onsubmit="return confirm('Удалить сделку?')">
                <button type="submit" class="btn btn-outline-danger"><i class="bi bi-trash"></i> Удалить</button>
              </form>
            </div>
          </div>
        </form>
      </div>

    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>