<!DOCTYPE html>
<html lang="ru">
<head><%- include('../partials/head') %>
<style>
.kanban-board { display: flex; gap: 1rem; overflow-x: auto; padding-bottom: 1rem; }
.kanban-col { min-width: 220px; flex: 1; background: #f1f5f9; border-radius: 12px; padding: 1rem; }
.kanban-col-title { font-weight: 600; font-size: .85rem; text-transform: uppercase; letter-spacing: .05em; margin-bottom: .75rem; }
.kanban-card { background: #fff; border-radius: 8px; padding: .75rem; margin-bottom: .5rem; border: 1px solid #e5e7eb; cursor: pointer; transition: box-shadow .2s; }
.kanban-card:hover { box-shadow: 0 4px 12px rgba(0,0,0,.1); }
.kanban-card .deal-title { font-weight: 600; font-size: .9rem; margin-bottom: .25rem; }
.kanban-card .deal-amount { font-size: .85rem; color: #6b7280; }
</style>
</head>
<body>
<div class="app-layout">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/navbar') %>
    <div class="page-content">

      <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 class="fw-bold mb-0">Сделки — Kanban</h5>
        <a href="/deals/new" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Новая сделка</a>
      </div>

      <div class="kanban-board">

        <% const cols = [
          { key: 'new', label: 'Новая', color: '#6b7280' },
          { key: 'negotiation', label: 'Переговоры', color: '#3b82f6' },
          { key: 'proposal', label: 'Предложение', color: '#8b5cf6' },
          { key: 'won', label: 'Выиграна', color: '#10b981' },
          { key: 'lost', label: 'Проиграна', color: '#ef4444' },
        ] %>

        <% cols.forEach(col => { %>
          <div class="kanban-col">
            <div class="kanban-col-title" style="color:<%= col.color %>">
              <%= col.label %>
              <span class="badge ms-1" style="background:<%= col.color %>"><%= kanban[col.key].length %></span>
            </div>

            <% kanban[col.key].forEach(deal => { %>
              <div class="kanban-card" onclick="window.location='/deals/<%= deal.id %>'">
                <div class="deal-title"><%= deal.title %></div>
                <div class="deal-amount"><%= deal.amount %> <%= deal.currency %></div>
                <% if (deal.client) { %>
                  <div class="text-muted" style="font-size:.8rem"><i class="bi bi-building me-1"></i><%= deal.client.name %></div>
                <% } %>
                <% if (deal.deadline) { %>
                  <div class="text-muted" style="font-size:.8rem"><i class="bi bi-calendar me-1"></i><%= new Date(deal.deadline).toLocaleDateString('ru-RU') %></div>
                <% } %>
              </div>
            <% }) %>

            <% if (kanban[col.key].length === 0) { %>
              <div class="text-center text-muted py-3" style="font-size:.85rem">Пусто</div>
            <% } %>
          </div>
        <% }) %>

      </div>

    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>