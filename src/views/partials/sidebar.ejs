<div class="sidebar d-flex flex-column p-3">
  <a href="/dashboard" class="sidebar-brand mb-4">
    <i class="bi bi-grid-fill me-2"></i>B2B CRM
  </a>
  <nav class="nav flex-column gap-1">
    <a href="/dashboard" class="nav-link <%= path === '/dashboard' ? 'active' : '' %>">
      <i class="bi bi-speedometer2 me-2"></i>Дашборд
    </a>
    <a href="/clients" class="nav-link <%= path.startsWith('/clients') ? 'active' : '' %>">
      <i class="bi bi-people me-2"></i>Клиенты
    </a>
    <a href="/deals" class="nav-link <%= path.startsWith('/deals') ? 'active' : '' %>">
      <i class="bi bi-kanban me-2"></i>Сделки
    </a>
    <a href="/invoices" class="nav-link <%= path.startsWith('/invoices') ? 'active' : '' %>">
      <i class="bi bi-receipt me-2"></i>Счета
    </a>
    <a href="/documents" class="nav-link <%= path.startsWith('/documents') ? 'active' : '' %>">
      <i class="bi bi-file-earmark-text me-2"></i>Документы
    </a>
    <a href="/tasks" class="nav-link <%= path.startsWith('/tasks') ? 'active' : '' %>">
      <i class="bi bi-check2-square me-2"></i>Задачи
    </a>
    <a href="/reports" class="nav-link <%= path.startsWith('/reports') ? 'active' : '' %>">
      <i class="bi bi-bar-chart me-2"></i>Отчёты
    </a>
  </nav>
  <div class="mt-auto">
    <form action="/auth/logout" method="POST">
      <button class="btn btn-outline-secondary w-100">
        <i class="bi bi-box-arrow-left me-2"></i>Выйти
      </button>
    </form>
  </div>
</div>