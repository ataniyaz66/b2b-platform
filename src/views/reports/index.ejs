<!DOCTYPE html>
<html lang="ru">
<head><%- include('../partials/head') %></head>
<body>
<div class="app-layout">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/navbar') %>
    <div class="page-content">

      <h5 class="fw-bold mb-4">Отчёты и аналитика</h5>

      <!-- Верхние карточки -->
      <div class="row g-3 mb-4">
        <div class="col-md-3">
          <div class="stat-card text-center">
            <div class="text-muted small mb-1">Оплачено всего</div>
            <div class="fs-3 fw-bold text-success"><%= paidTotal.toLocaleString('ru-RU') %></div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="stat-card text-center">
            <div class="text-muted small mb-1">Всего сделок</div>
            <div class="fs-3 fw-bold"><%= dealsByStage.reduce((s, d) => s + parseInt(d.count), 0) %></div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="stat-card text-center">
            <div class="text-muted small mb-1">Выиграно сделок</div>
            <div class="fs-3 fw-bold text-success">
              <%= (dealsByStage.find(d => d.stage === 'won') || {count: 0}).count %>
            </div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="stat-card text-center">
            <div class="text-muted small mb-1">Просроченных счетов</div>
            <div class="fs-3 fw-bold text-danger">
              <%= (invoicesByStatus.find(i => i.status === 'overdue') || {count: 0}).count %>
            </div>
          </div>
        </div>
      </div>

      <div class="row g-3">

        <!-- Сделки по стадиям -->
        <div class="col-md-6">
          <div class="stat-card">
            <h6 class="fw-semibold mb-3">Сделки по стадиям</h6>
            <% const stageMap = { new: 'Новая', negotiation: 'Переговоры', proposal: 'Предложение', won: 'Выиграна', lost: 'Проиграна' } %>
            <% const stageBadge = { new: 'secondary', negotiation: 'primary', proposal: 'info', won: 'success', lost: 'danger' } %>
            <% if (dealsByStage.length === 0) { %>
              <p class="text-muted">Сделок пока нет</p>
            <% } else { %>
              <% dealsByStage.forEach(d => { %>
                <div class="d-flex justify-content-between align-items-center mb-2">
                  <span class="badge bg-<%= stageBadge[d.stage] %>"><%= stageMap[d.stage] || d.stage %></span>
                  <span class="fw-semibold"><%= d.count %> шт. / <%= parseFloat(d.total || 0).toLocaleString('ru-RU') %></span>
                </div>
              <% }) %>
            <% } %>
          </div>
        </div>

        <!-- Счета по статусам -->
        <div class="col-md-6">
          <div class="stat-card">
            <h6 class="fw-semibold mb-3">Счета по статусам</h6>
            <% const invBadge = { issued: 'primary', pending: 'warning', paid: 'success', overdue: 'danger' } %>
            <% const invMap = { issued: 'Выставлен', pending: 'Ожидает', paid: 'Оплачен', overdue: 'Просрочен' } %>
            <% if (invoicesByStatus.length === 0) { %>
              <p class="text-muted">Счетов пока нет</p>
            <% } else { %>
              <% invoicesByStatus.forEach(i => { %>
                <div class="d-flex justify-content-between align-items-center mb-2">
                  <span class="badge bg-<%= invBadge[i.status] %>"><%= invMap[i.status] || i.status %></span>
                  <span class="fw-semibold"><%= i.count %> шт. / <%= parseFloat(i.total || 0).toLocaleString('ru-RU') %></span>
                </div>
              <% }) %>
            <% } %>
          </div>
        </div>

        <!-- Топ клиенты -->
        <div class="col-md-6">
          <div class="stat-card">
            <h6 class="fw-semibold mb-3">Топ-5 клиентов по сумме сделок</h6>
            <% if (topClients.length === 0) { %>
              <p class="text-muted">Сделок пока нет</p>
            <% } else { %>
              <% topClients.forEach((c, i) => { %>
                <div class="d-flex justify-content-between align-items-center mb-2">
                  <span><span class="text-muted me-2">#<%= i + 1 %></span><%= c['client.name'] || '—' %></span>
                  <span class="fw-semibold"><%= parseFloat(c.total || 0).toLocaleString('ru-RU') %></span>
                </div>
              <% }) %>
            <% } %>
          </div>
        </div>

        <!-- Задачи -->
        <div class="col-md-6">
          <div class="stat-card">
            <h6 class="fw-semibold mb-3">Задачи по статусам</h6>
            <% const taskBadge = { open: 'secondary', in_progress: 'primary', done: 'success' } %>
            <% const taskMap = { open: 'Открыта', in_progress: 'В работе', done: 'Закрыта' } %>
            <% if (tasksByStatus.length === 0) { %>
              <p class="text-muted">Задач пока нет</p>
            <% } else { %>
              <% tasksByStatus.forEach(t => { %>
                <div class="d-flex justify-content-between align-items-center mb-2">
                  <span class="badge bg-<%= taskBadge[t.status] %>"><%= taskMap[t.status] || t.status %></span>
                  <span class="fw-semibold"><%= t.count %> шт.</span>
                </div>
              <% }) %>
            <% } %>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>